{
  "name": "smart-parking-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:affected": "vitest run --changed origin/develop --passWithNoTests",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "e2e:open": "cypress open",
    "e2e:smoke": "cypress run --spec \"cypress/e2e/smoke/**/*.cy.ts\"",
    "e2e:ci": "start-server-and-test dev http://localhost:5173 e2e:smoke",
    "e2e:local": "pwsh -NoProfile -File ../scripts/run-e2e-local.ps1",
    "e2e:local:open": "pwsh -NoProfile -File ../scripts/run-e2e-local.ps1 -Mode open",
    "e2e:local:stack": "pwsh -NoProfile -File ../scripts/run-e2e-local.ps1 -Mode stack"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/inter": "^5.2.8",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@mui/x-charts": "^8.29.0",
    "@mui/x-data-grid": "^9.5.0",
    "@tanstack/react-query": "^5.80.7",
    "axios": "^1.7.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.30",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^3.2.6",
    "cypress": "^14.5.4",
    "jsdom": "^27.0.1",
    "start-server-and-test": "^2.1.5",
    "typescript": "^5.7.2",
    "vite": "^6.3.5",
    "vitest": "^3.2.6"
  }
}
