# =============================================================================
# Smart Parking — .gitignore
# =============================================================================

# --- Dependencies ---
node_modules/
backend/node_modules/
frontend/node_modules/

# --- Build output ---
dist/
backend/dist/
frontend/dist/
payment-service/target/
target/
*.class
*.tsbuildinfo

# --- Frontend tooling ---
frontend/.vite/
frontend/coverage/
frontend/cypress/screenshots/
frontend/cypress/videos/
frontend/cypress/downloads/

# --- Test coverage ---
coverage/
backend/coverage/

# --- Environment & secrets ---
.env
.env.local
.env.*.local
backend/.env
backend/.env.local
frontend/.env
frontend/.env.local
payment-service/.env
payment-service/.env.local
payment-service/src/main/resources/application-local.properties
payment-service/src/main/resources/application-dev.properties

# Keep examples
!.env.example
!backend/.env.example
!frontend/.env.example

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
hs_err_pid*
replay_pid*

# --- Agent / IDE / shell session artifacts ---
agent-tools/
agent-artifacts/
terminals/
mcps/
.cursor/
.vscode/
.idea/
*.iml

# --- Grok: ephemeral only (prompts, reports, agent-runs stay tracked) ---
.grok/cache/
.grok/tmp/
.grok/logs/
.grok/sessions/
.grok/*.log
!.grok/agent-runs/
!.grok/agent-runs/**

# --- Local personal notes (not for repo) ---
local-printouts/

# --- Payment-service local / generated ---
payment-service/.github/

# --- GitHub Copilot App Modernization tool output ---
.github/modernize/

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# --- Java / Maven ---
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# --- Misc caches & deploy artifacts ---
.eslintcache
.cache/
.turbo/
.vercel/