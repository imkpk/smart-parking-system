generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  ADMIN
  SECURITY
  USER
}

enum OrganizationPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum SlotStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum ParkingLotType {
  APARTMENT
  MALL
  HOSPITAL
  OFFICE
  PUBLIC
}

enum SlotType {
  CAR
  BIKE
  EV
  HANDICAPPED
}

enum VehicleType {
  CAR
  BIKE
  EV
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  EXPIRED
}

enum ParkingEventStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AssignmentStatus {
  ACTIVE
  REVOKED
}

enum ConversationType {
  SECURITY
  CUSTOMER_CARE
}

enum ConversationStatus {
  OPEN
  RESOLVED
}

model Organization {
  id                   Int                   @id @default(autoincrement())
  name                 String
  slug                 String                @unique
  organizationType     ParkingLotType        @default(APARTMENT) @map("organization_type")
  logoUrl              String?
  primaryColor         String?
  secondaryColor       String?
  accentColor          String?
  loginTitle           String?
  supportEmail         String?
  plan                 OrganizationPlan      @default(STARTER)
  maxParkingLots       Int                   @default(5) @map("maxLots")
  maxUsers             Int                   @default(50)
  isActive             Boolean               @default(true)
  users                User[]
  parkingLots          ParkingLot[]
  vehicles             Vehicle[]
  bookings             Booking[]
  parkingEvents        ParkingEvent[]
  assignments          SlotAssignment[]
  conversations        Conversation[]
  conversationMessages ConversationMessage[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@map("organizations")
}

model User {
  id                       Int                   @id @default(autoincrement())
  organizationId           Int?
  name                     String
  email                    String
  phone                    String?
  passwordHash             String
  role                     Role                  @default(USER)
  isActive                 Boolean               @default(true)
  organization             Organization?         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  vehicles                 Vehicle[]
  bookings                 Booking[]
  parkingEvents            ParkingEvent[]
  assignments              SlotAssignment[]
  createdConversations     Conversation[]        @relation("ConversationCreatedBy")
  assignedConversations    Conversation[]        @relation("ConversationAssignedTo")
  sentConversationMessages ConversationMessage[] @relation("ConversationMessageSender")
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt

  @@unique([organizationId, email])
  @@unique([organizationId, phone])
  @@index([organizationId])
  @@map("users")
}

model ParkingLot {
  id             Int            @id @default(autoincrement())
  organizationId Int
  name           String
  type           ParkingLotType @default(APARTMENT)
  address        String?
  city           String?
  state          String?
  pincode        String?
  isActive       Boolean        @default(true)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  floors         Floor[]
  bookings       Booking[]
  parkingEvents  ParkingEvent[]
  conversations  Conversation[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId])
  @@map("parking_lots")
}

model Floor {
  id           Int        @id @default(autoincrement())
  name         String
  level        Int?
  parkingLotId Int
  parkingLot   ParkingLot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  slots        Slot[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([parkingLotId, name])
  @@index([parkingLotId])
  @@map("floors")
}

model Slot {
  id          Int              @id @default(autoincrement())
  slotNumber  String
  slotType    SlotType         @default(CAR) @map("type")
  status      SlotStatus       @default(AVAILABLE)
  floorId     Int
  floor       Floor            @relation(fields: [floorId], references: [id], onDelete: Cascade)
  assignments SlotAssignment[]
  events      ParkingEvent[]
  bookings    Booking[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([floorId, slotNumber])
  @@index([floorId])
  @@index([status])
  @@map("parking_slots")
}

model Vehicle {
  id             Int              @id @default(autoincrement())
  organizationId Int
  userId         Int              @map("ownerId")
  vehicleNumber  String           @map("registrationNo")
  vehicleType    VehicleType      @default(CAR) @map("type")
  brand          String?          @map("make")
  model          String?
  color          String?
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments    SlotAssignment[]
  events         ParkingEvent[]
  bookings       Booking[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, vehicleNumber])
  @@index([userId], map: "vehicles_ownerId_idx")
  @@index([organizationId])
  @@map("vehicles")
}

model Booking {
  id             Int            @id @default(autoincrement())
  organizationId Int
  userId         Int
  vehicleId      Int
  slotId         Int
  parkingLotId   Int
  status         BookingStatus  @default(CONFIRMED)
  startTime      DateTime
  endTime        DateTime?
  bookingCode    String         @unique
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle        Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  slot           Slot           @relation(fields: [slotId], references: [id], onDelete: Cascade)
  parkingLot     ParkingLot     @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  parkingEvents  ParkingEvent[]
  conversations  Conversation[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId])
  @@index([userId])
  @@index([vehicleId])
  @@index([slotId])
  @@index([parkingLotId])
  @@index([status])
  @@map("bookings")
}

model SlotAssignment {
  id             Int              @id @default(autoincrement())
  organizationId Int
  userId         Int
  vehicleId      Int
  slotId         Int
  status         AssignmentStatus @default(ACTIVE)
  assignedAt     DateTime         @default(now())
  revokedAt      DateTime?
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle        Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  slot           Slot             @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([vehicleId])
  @@index([slotId])
  @@index([status])
  @@map("slot_assignments")
}

model ParkingEvent {
  id              Int                @id @default(autoincrement())
  organizationId  Int
  bookingId       Int
  userId          Int
  vehicleId       Int
  slotId          Int
  parkingLotId    Int
  checkInTime     DateTime
  checkOutTime    DateTime?
  status          ParkingEventStatus @default(ACTIVE)
  durationMinutes Int?
  feeAmount       Decimal?           @db.Decimal(10, 2)
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  booking         Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle         Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  slot            Slot               @relation(fields: [slotId], references: [id], onDelete: Cascade)
  parkingLot      ParkingLot         @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([bookingId])
  @@index([organizationId])
  @@index([userId])
  @@index([vehicleId])
  @@index([slotId])
  @@index([parkingLotId])
  @@index([status])
  @@map("parking_events")
}

model Conversation {
  id               Int                @id @default(autoincrement())
  organizationId   Int
  type             ConversationType
  status           ConversationStatus @default(OPEN)
  subject          String?
  createdByUserId  Int
  assignedToUserId Int?
  parkingLotId     Int?
  bookingId        Int?
  lastMessageAt    DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdByUser  User                  @relation("ConversationCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  assignedToUser User?                 @relation("ConversationAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  parkingLot     ParkingLot?           @relation(fields: [parkingLotId], references: [id], onDelete: SetNull)
  booking        Booking?              @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  messages       ConversationMessage[]

  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@index([createdByUserId])
  @@index([assignedToUserId])
  @@index([parkingLotId])
  @@index([bookingId])
  @@map("conversations")
}

model ConversationMessage {
  id             Int      @id @default(autoincrement())
  organizationId Int
  conversationId Int
  senderId       Int
  body           String   @db.Text
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("ConversationMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([conversationId])
  @@index([senderId])
  @@map("conversation_messages")
}
