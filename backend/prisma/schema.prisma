generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Role {
  ADMIN
  SECURITY
  USER
}

enum SlotStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum ParkingLotType {
  APARTMENT
  MALL
  HOSPITAL
  OFFICE
  PUBLIC
}

enum SlotType {
  CAR
  BIKE
  EV
  HANDICAPPED
}

enum VehicleType {
  CAR
  BIKE
  EV
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  EXPIRED
}

enum AssignmentStatus {
  ACTIVE
  REVOKED
}

enum ParkingEventType {
  ENTRY
  EXIT
}

model User {
  id           Int              @id @default(autoincrement())
  name         String
  email        String           @unique
  phone        String?          @unique
  passwordHash String
  role         Role             @default(USER)
  isActive     Boolean          @default(true)
  vehicles     Vehicle[]
  bookings     Booking[]
  assignments  SlotAssignment[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("users")
}

model ParkingLot {
  id        Int            @id @default(autoincrement())
  name      String
  type      ParkingLotType @default(APARTMENT)
  address   String?
  city      String?
  state     String?
  pincode   String?
  isActive  Boolean        @default(true)
  floors    Floor[]
  bookings  Booking[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("parking_lots")
}

model Floor {
  id           Int         @id @default(autoincrement())
  name         String
  level        Int?
  parkingLotId Int
  parkingLot   ParkingLot  @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  slots        Slot[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([parkingLotId, name])
  @@index([parkingLotId])
  @@map("floors")
}

model Slot {
  id          Int              @id @default(autoincrement())
  slotNumber  String
  slotType    SlotType         @default(CAR) @map("type")
  status      SlotStatus       @default(AVAILABLE)
  floorId     Int
  floor       Floor            @relation(fields: [floorId], references: [id], onDelete: Cascade)
  assignments SlotAssignment[]
  events      ParkingEvent[]
  bookings    Booking[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([floorId, slotNumber])
  @@index([floorId])
  @@index([status])
  @@map("parking_slots")
}

model Vehicle {
  id            Int              @id @default(autoincrement())
  userId        Int              @map("ownerId")
  vehicleNumber String           @unique(map: "vehicles_registrationNo_key") @map("registrationNo")
  vehicleType   VehicleType      @default(CAR) @map("type")
  brand         String?          @map("make")
  model         String?
  color         String?
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments   SlotAssignment[]
  events        ParkingEvent[]
  bookings      Booking[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId], map: "vehicles_ownerId_idx")
  @@map("vehicles")
}

model Booking {
  id           Int           @id @default(autoincrement())
  userId       Int
  vehicleId    Int
  slotId       Int
  parkingLotId Int
  status       BookingStatus @default(CONFIRMED)
  startTime    DateTime
  endTime      DateTime?
  bookingCode  String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle      Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  slot         Slot          @relation(fields: [slotId], references: [id], onDelete: Cascade)
  parkingLot   ParkingLot    @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId])
  @@index([vehicleId])
  @@index([slotId])
  @@index([parkingLotId])
  @@index([status])
  @@map("bookings")
}

model SlotAssignment {
  id         Int              @id @default(autoincrement())
  userId     Int
  vehicleId  Int
  slotId     Int
  status     AssignmentStatus @default(ACTIVE)
  assignedAt DateTime         @default(now())
  revokedAt  DateTime?
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle    Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  slot       Slot             @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([vehicleId])
  @@index([slotId])
  @@index([status])
  @@map("slot_assignments")
}

model ParkingEvent {
  id        Int              @id @default(autoincrement())
  type      ParkingEventType
  vehicleId Int
  slotId    Int?
  notes     String?
  createdAt DateTime         @default(now())
  vehicle   Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  slot      Slot?            @relation(fields: [slotId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([slotId])
  @@index([type])
  @@index([createdAt])
  @@map("parking_events")
}
