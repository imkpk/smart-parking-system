# PostgreSQL (Neon hosted — use sslmode=require)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST/SHADOW_DB?sslmode=require"

# PostgreSQL (local development)
# DATABASE_URL="postgresql://parking_user:parking_password@localhost:5432/smart_parking_db?schema=public"
# SHADOW_DATABASE_URL="postgresql://parking_user:parking_password@localhost:5432/smart_parking_shadow_db?schema=public"

PORT=3000
JWT_SECRET="smart_parking_dev_jwt_secret_32_chars_minimum"
JWT_EXPIRES_IN="1d"
PAYMENT_SERVICE_URL="http://localhost:8081"

# Comma-separated frontend origins (Vercel + local dev)
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
# Legacy alias (still supported):
# CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Smart Parking <noreply@smartparking.com>"
FRONTEND_URL=https://parking.imkpk.in

# Transactional outbox worker (Postgres-only; no external broker)
OUTBOX_WORKER_ENABLED=true
OUTBOX_WORKER_INTERVAL_MS=5000
OUTBOX_WORKER_BATCH_SIZE=10

# WARNING: NestJS backend uses PostgreSQL after Phase 6A.
# Existing local MySQL parking_lot_db is not used by this backend.
# payment-service uses PostgreSQL (parking_payment_db) — see payment-service/README.md.